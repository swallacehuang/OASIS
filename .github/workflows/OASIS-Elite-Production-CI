name: OASIS Elite Production CI

on:
  push:
    branches: [main, master]
  pull_request:
  workflow_dispatch:

permissions:
  contents: read
  security-events: write

concurrency:
  group: oasis-${{ github.ref }}
  cancel-in-progress: true

jobs:
  quality:
    name: Lint / Test / Build
    runs-on: ubuntu-latest

    strategy:
      fail-fast: false
      matrix:
        python-version: ["3.10", "3.11", "3.12"]

    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
      PIP_DISABLE_PIP_VERSION_CHECK: 1
      PYTHONUNBUFFERED: 1

    steps:
      - name: Checkout source
        uses: actions/checkout@v5

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.python-version }}
          cache: pip

      - name: Install system tooling
        run: |
          python -m pip install --upgrade pip setuptools wheel

      - name: Install project dependencies
        run: |
          if [ -f requirements.txt ]; then
            pip install -r requirements.txt
          fi

          pip install \
            pytest \
            pytest-cov \
            flake8 \
            black \
            isort \
            build \
            pip-audit

          if [ -f pyproject.toml ] || [ -f setup.py ]; then
            pip install -e .
          fi

      - name: Validate formatting (Black)
        run: |
          black --check . || true

      - name: Validate imports (isort)
        run: |
          isort . --check-only || true

      - name: Lint (flake8 critical)
        run: |
          flake8 . --count --select=E9,F63,F7,F82 --show-source --statistics

      - name: Lint (style report)
        run: |
          flake8 . --count --exit-zero --max-complexity=12 --max-line-length=127 --statistics

      - name: Run tests
        run: |
          if [ -d tests ]; then
            pytest -v --cov=. --cov-report=xml
          else
            echo "No tests directory found."
          fi

      - name: Build package
        run: |
          python -m build

      - name: Dependency audit
        run: |
          pip-audit || true

      - name: Upload coverage artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: coverage-${{ matrix.python-version }}
          path: coverage.xml
          if-no-files-found: ignore

      - name: Upload dist artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: dist-${{ matrix.python-version }}
          path: dist/
          if-no-files-found: ignore

  codeql:
    name: CodeQL Security Scan
    runs-on: ubuntu-latest

    permissions:
      contents: read
      security-events: write

    steps:
      - name: Checkout source
        uses: actions/checkout@v5

      - name: Initialize CodeQL
        uses: github/codeql-action/init@v4
        with:
          languages: python

      - name: Autobuild
        uses: github/codeql-action/autobuild@v4

      - name: Analyze
        uses: github/codeql-action/analyze@v4
